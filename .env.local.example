# ============================================================
# OBLIGATORIO — la app no arrancará sin estas variables.
# ============================================================

# Supabase (Configuración del proyecto → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clave service-role de Supabase. Omite RLS; solo se usa en rutas del
# servidor (webhook, motor de automatizaciones y autenticación de API keys
# públicas — ver docs/public-api.md). Mantener en secreto — nunca pegarla
# en código de cliente.
#
# Nota: la API pública (/api/v1) no necesita otra variable de entorno.
# Las API keys se crean en el panel (Configuración → API keys) y se
# almacenan hasheadas en la base de datos; esta clave service-role es
# lo que permite al sistema de autenticación buscar una clave presentada
# sin necesidad de sesión de usuario.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cifrado de tokens de WhatsApp (64 caracteres hex = 32 bytes, AES-256-GCM).
# Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotar este valor deja huérfanos todos los tokens cifrados con la clave
# anterior — los usuarios tienen que volver a guardar su configuración de
# WhatsApp para reconectar.
ENCRYPTION_KEY=your-64-char-hex-key-here

# Meta App Secret (Meta for Developers → App Settings → Basic).
# Verifica la firma HMAC-SHA256 de cada POST entrante del webhook.
# Obligatorio — sin esta variable el webhook rechaza todas las peticiones.
META_APP_SECRET=your-meta-app-secret

# ============================================================
# CULQI — pasarela de pagos peruana (Yape, Plin, tarjeta)
# ============================================================
# Obtén tus llaves en https://dashboard.culqi.com/ > Desarrollo > API Keys
# CULQI_PUBLIC_KEY=pk_test_...
# CULQI_SECRET_KEY=sk_test_...

# ============================================================
# RECOMENDADO — existen valores por defecto seguros, pero querrás configurar esto.
# ============================================================

# URL pública canónica de este despliegue (esquema + host, sin barra final).
# Se usa para el sitemap y las imágenes OG. Las rutas que necesitan una URL
# autorreferencial (enlaces de invitación desde /api/account/invitations,
# cualquier enlace futuro por email) derivan el origen de la propia petición,
# así que esta variable *solo* es necesaria cuando el origen derivado de la
# petición sería incorrecto — por ejemplo, al generar enlaces desde un cron job
# o un worker en background que no tiene petición entrante.
NEXT_PUBLIC_SITE_URL=https://crm.example.com

# Locale de idioma por defecto (ej. en, es)
NEXT_PUBLIC_APP_LOCALE=es

# ============================================================
# PORTAL DE ADMINISTRACIÓN
# ============================================================

# Email del propietario SaaS / super-admin. Cuando este usuario inicia sesión,
# es redirigido a /admin en lugar de /dashboard y puede gestionar todas las
# cuentas, planes, feature flags y ver logs de auditoría.
SAAS_OWNER_EMAIL=brunovarillas@gmail.com

# Clave secreta para endpoints de cron jobs (ej. verificador de expiración
# de trial). Debe coincidir con el token Authorization Bearer enviado por
# Vercel Cron Jobs.
CRON_SECRET=your-cron-secret-here

# Cuando se configura como "true", todas las rutas no-admin y no-estáticas se
# reescriben a /maintenance. El super-admin sigue pudiendo acceder a /admin
# normalmente.
MAINTENANCE_MODE=false

# ============================================================
# OPCIONAL — solo necesario si usas la funcionalidad.
# ============================================================

# Lista de seguridad (defense-in-depth) de hostnames que
# /api/account/invitations puede publicar en URLs de invitación.
# Separados por comas, sin esquema, sin puerto (solo hostnames).
#
# Por qué existe: cuando NEXT_PUBLIC_SITE_URL no está configurada, las URLs
# de invitación se derivan de la cabecera `Host` / `X-Forwarded-Host` de la
# petición entrante. En un despliegue con proxy típico, el proxy establece
# estos valores a tu hostname canónico y son fiables. En un despliegue *sin
# proxy* expuesto a internet público, un atacante podría hacer POST a la API
# directamente con un `Host: phishing.example` falsificado y recibir una URL
# de invitación apuntando a su sitio.
#
# Cuando esta variable está configurada, los hostnames que no estén en la
# lista se rechazan (la petición cae al fallback de CodixIA con un
# console.warn). Cuando no está configurada, el comportamiento es igual que
# en versiones anteriores — se confía en el host derivado de la petición.
#
# La mayoría de operadores no necesitan esto: configurar NEXT_PUBLIC_SITE_URL
# con tu URL canónica ya fija los enlaces de invitación ahí. Esto es para
# operadores que quieren doble seguridad o ejecutan setups multi-tenant donde
# una instancia de la app sirve varios hostnames.
#
# Ejemplo:
#   ALLOWED_INVITE_HOSTS=crm.example.com,crm-staging.example.com

# Secreto compartido que protege GET /api/automations/cron. Necesario si
# usas pasos "Wait" en automatizaciones (un pinger programado drena las
# ejecuciones pendientes). Generar una cadena larga aleatoria:
#   openssl rand -hex 32
# Ver docs/automations-and-cron.md.
# AUTOMATION_CRON_SECRET=generate-a-long-random-string

# Meta App ID (Meta for Developers → App Settings → Basic). Necesario para
# crear/editar plantillas de mensajes con cabecera IMAGE: Meta solo acepta un
# handle de media Resumable-Upload (no una URL plana) como muestra de cabecera,
# y esa subida es scope-de-app. Sin esto, el envío de plantilla con cabecera
# de imagen devuelve un error claro; las plantillas solo de texto/cuerpo no se
# ven afectadas. Usar junto con META_APP_SECRET.
# META_APP_ID=your-meta-app-id

# Cuando es "true", POST /api/whatsapp/templates/submit se salta la llamada a
# Meta y almacena la fila con un meta_template_id sintético `dry-run-<uuid>`.
# Configurar esto en CI y desarrollo local para probar toda la UI de plantillas
# sin un WABA real. Dejar sin configurar (o "false") en producción.
# WHATSAPP_TEMPLATES_DRY_RUN=true

# ------------------------------------------------------------------
# Asistente de respuesta IA (opcional)
# ------------------------------------------------------------------
# El asistente IA funciona con tu propia clave (bring-your-own-key): cada
# cuenta pega su propia clave de OpenAI o Anthropic en Configuración →
# Asistente IA. La clave se almacena cifrada con AES-256-GCM usando
# ENCRYPTION_KEY (arriba) — NO hay variable de entorno con clave global
# del proveedor, y nada aquí es necesario para que la funcionalidad
# funcione. Las dos variables de abajo solo ajustan el comportamiento.
#
# La base de conocimiento IA (migración 030) usa búsqueda de texto completo
# de Postgres de fábrica. La búsqueda semántica opcional necesita la extensión
# `pgvector` — la migración 030 ejecuta `CREATE EXTENSION IF NOT EXISTS vector`
# (Supabase la tiene disponible) — más una clave de embeddings por cuenta
# configurada en Configuración → Asistente IA. Tampoco se necesita variable
# de entorno.

# Timeout por petición al proveedor, en milisegundos. Por defecto 30000.
# AI_REQUEST_TIMEOUT_MS=30000

# Cuántos mensajes de texto recientes de una conversación enviar al modelo
# como contexto (borrador + auto-respuesta). Por defecto 20.
# AI_CONTEXT_MESSAGE_LIMIT=20

# ============================================================
# NOTIFICACIONES PUSH (PWA) — opcional
# ============================================================
# Claves VAPID para notificaciones Web Push. Generar con:
#   npx web-push generate-vapid-keys
# Luego pegar la clave pública aquí (el prefijo NEXT_PUBLIC_ la hace
# disponible al código de cliente) y la clave privada en VAPID_PRIVATE_KEY.
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key-here
# VAPID_PRIVATE_KEY=your-private-key-here

NEXT_PUBLIC_VAPID_PUBLIC_KEY=BOjK6K4SEdDhiEoF9ZhJwyD1iBkpZeqbbXS2mspLFOx5qY99BrzMkCTIvWIEyMJQTsQs3RgLmDgcnqmpmfguP5k
VAPID_PRIVATE_KEY=89cXI3tWtJq0NWbBPi_35SB7-81bgWs9WNjjGha9WAY
NEXT_PUBLIC_APP_LOCALE=es
